# Public site settings
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_RAZORPAY_PAYMENT_PAGE_URL=https://pages.razorpay.com/YOUR_PAYMENT_PAGE_SLUG
NEXT_PUBLIC_SUPPORT_WHATSAPP=91XXXXXXXXXX
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_BRAND_NAME=Punjab Ghar Toolkit

# Razorpay webhook secret from Dashboard > Account & Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=toolkit-files

# Private file paths inside the Supabase Storage bucket
MISTAKES_FILE_PATH=mistakes-pdf.pdf
CHECKLIST_FILE_PATH=site-checklist.pdf
CALCULATOR_FILE_PATH=grey-structure-calculator.xlsx

# Resend email settings
# NOTE: For testing use onboarding@resend.dev. For live launch, verify your own
# domain on resend.com and use: Punjab Ghar Toolkit <support@yourdomain.com>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
DELIVERY_FROM_EMAIL=Punjab Ghar Toolkit <onboarding@resend.dev>
DELIVERY_REPLY_TO=support@example.com

# Admin secret for manual email resend route (/api/resend-email)
# Set this to any long random string. Keep it private — never share it publicly.
# Generate one at: https://generate-secret.vercel.app/32
ADMIN_SECRET=replace_with_a_long_random_secret
